# ── RecruitBot Environment Configuration ──

# App Settings
APP_NAME=RecruitBot
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173

# Database Settings (Sprint 0.2)
DATABASE_URL=postgresql://recruitbot_user:recruitbot_password@localhost:5432/recruitbot_db
POSTGRES_USER=recruitbot_user
POSTGRES_PASSWORD=recruitbot_password
POSTGRES_DB=recruitbot_db

# LLM Gateway API Keys (Sprint 0.3)
# Anthropic API Key (Required for Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Voyage AI API Key (Required for Success Vector Embeddings)
VOYAGE_API_KEY=your-voyage-api-key-here

# Security & Auth (Sprint 0.4)
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET_KEY=change-this-to-a-very-secure-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
